# Relay — Environment Variables
# Copy this file to .env and fill in your values.

# Flask secret key (generate a random one: python3 -c "import secrets; print(secrets.token_hex(32))")
RELAY_SECRET_KEY=change-me-to-a-random-secret-key

# Set to "production" for HTTPS + secure cookies
RELAY_ENV=development

# Database URL (leave blank for SQLite local, set to PostgreSQL on Render)
DATABASE_URL=

# Port (Render sets this automatically)
PORT=8000

# ── Feature flags ──
# Set to "true" to force all skills to cost exactly 1 credit (original behavior)
RELAY_FLAT_RATE=false
# Maximum credits a teacher can charge per session
RELAY_MAX_CREDIT_COST=4
# Starter credits for new verified users
RELAY_STARTER_CREDITS=3
# Supply-only mode: only users with listings can book sessions
RELAY_SUPPLY_ONLY_MODE=false
# Enable monetization UI (top-ups, memberships) — still a stub, no real payments
RELAY_MONETIZATION_ENABLED=false
